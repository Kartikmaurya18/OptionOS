{
  "title": "Straddle Platform Overview",
  "uid": "straddle-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Tick Ingest Rate",
      "description": "rate(ticks_ingested_total) -- ticks/sec applied to each asset's OptionStore",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ticks_ingested_total[1m])",
          "legendFormat": "{{asset}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Tick-to-Publish Latency (p50 / p95 / p99)",
      "description": "Time from receiving a raw Delta WS frame to publishing the derived update onto Redis",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(tick_to_publish_seconds_bucket[1m])) by (le, asset))",
          "legendFormat": "p50 {{asset}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(tick_to_publish_seconds_bucket[1m])) by (le, asset))",
          "legendFormat": "p95 {{asset}}"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(tick_to_publish_seconds_bucket[1m])) by (le, asset))",
          "legendFormat": "p99 {{asset}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Option Store Rows",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "option_store_row_count",
          "legendFormat": "{{asset}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Candle Engine Active Keys",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "candle_engine_active_keys",
          "legendFormat": "{{asset}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Gateway Connected Clients",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "gateway_connected_clients"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Delta Reconnects (5m)",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "orange" }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(delta_reconnects_total[5m])",
          "legendFormat": "{{asset}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Backfill Query Latency (p95)",
      "description": "Time to serve a /api/candles request",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(backfill_query_seconds_bucket[5m])) by (le, asset))",
          "legendFormat": "p95 {{asset}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Tick Persistence Batch Size",
      "description": "Entries written to ClickHouse per batch -- avg over each window",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(tick_persistence_batch_written_size_sum[1m]) / rate(tick_persistence_batch_written_size_count[1m])",
          "legendFormat": "avg batch size"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Dropped Sends / Persistence Write Errors",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(gateway_dropped_sends_total[5m])",
          "legendFormat": "gateway dropped sends"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(tick_persistence_write_errors_total[5m])",
          "legendFormat": "clickhouse write errors"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Process Resident Memory",
      "description": "process_resident_memory_bytes -- free from prometheus_client's default process collector",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_resident_memory_bytes"
        }
      ]
    }
  ]
}
