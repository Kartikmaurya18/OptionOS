STRADDLE_DELTA_REST_URL=https://api.india.delta.exchange
STRADDLE_DELTA_WS_URL=wss://socket.india.delta.exchange
STRADDLE_ASSETS=["BTC","ETH"]
STRADDLE_UNDERLYING=BTC
STRADDLE_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Local dev: `docker compose -f infra/docker-compose.yml up -d redis` publishes
# on 16379 (not 6379 -- avoids colliding with any other Redis already running
# on this machine's default port). Production points this at the managed/
# in-cluster Redis instead (see infra/k8s).
STRADDLE_REDIS_URL=redis://localhost:16379/0

# Local dev: `docker compose -f infra/docker-compose.yml up -d clickhouse`
# publishes HTTP on 18123 (not 8123), same reasoning as Redis above.
STRADDLE_CLICKHOUSE_HOST=localhost
STRADDLE_CLICKHOUSE_PORT=18123
STRADDLE_CLICKHOUSE_USER=straddle
STRADDLE_CLICKHOUSE_PASSWORD=straddle
STRADDLE_CLICKHOUSE_DATABASE=straddle
